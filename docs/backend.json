
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and personal settings within the MemoryLane application.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Authentication UID. Immutable system-generated ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "username": { "type": "string", "description": "Unique user-defined handle/social identifier." },
        "dateOfBirth": { "type": "string", "format": "date-time", "description": "Stored as a Timestamp to calculate age dynamically." },
        "age": { "type": "number", "description": "Derived from dateOfBirth." },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt", "updatedAt"]
    },
    "Scrapbook": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Scrapbook",
      "type": "object",
      "description": "Represents a digital scrapbook containing pages and collaborators.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the owner. Stable identifier for ownership." },
        "category": { "type": "string", "enum": ["Holiday", "Birthday", "Family", "Wedding", "Other"] },
        "pageCount": { "type": "number", "description": "Total number of pages in the scrapbook." },
        "members": { 
          "type": "object", 
          "description": "Map of UID to role: 'owner', 'editor', or 'viewer'.",
          "additionalProperties": { "type": "string" }
        },
        "sharedWith": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of UIDs of users who have been granted access (excluding owner)."
        },
        "isFinalized": { "type": "boolean" },
        "isPublic": { "type": "boolean" },
        "coverImage": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "ownerId", "category", "members", "createdAt", "updatedAt"]
    },
    "Page": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Page",
      "type": "object",
      "description": "Represents a single page within a scrapbook.",
      "properties": {
        "id": { "type": "string" },
        "scrapbookId": { "type": "string" },
        "pageNumber": { "type": "number" },
        "backgroundColor": { "type": "string", "default": "#ffffff", "description": "Hex code for the canvas background." },
        "members": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "scrapbookId", "pageNumber", "members"]
    },
    "CanvasObject": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CanvasObject",
      "type": "object",
      "description": "A multimedia element on a page.",
      "properties": {
        "id": { "type": "string" },
        "pageId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "audio", "text", "shape"] },
        "shapeType": { "type": "string", "enum": ["none", "circle", "square", "rectangle", "triangle"], "default": "none" },
        "fillColor": { "type": "string", "default": "#f1b36a" },
        "mediaUri": { "type": "string", "format": "uri" },
        "text": { "type": "string" },
        "textColor": { "type": "string", "default": "#000000" },
        "alpha": { "type": "number", "default": 100, "description": "Opacity from 0 to 100" },
        "isBold": { "type": "boolean" },
        "isUnderline": { "type": "boolean" },
        "fontSize": { "type": "number", "default": 24 },
        "fontFamily": { "type": "string", "enum": ["font-serif", "font-sans", "font-mono"], "default": "font-serif" },
        "borderWidth": { "type": "number", "default": 0 },
        "borderColor": { "type": "string", "default": "#000000" },
        "volume": { "type": "number", "default": 100, "description": "Audio volume from 0 to 100" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "rotation": { "type": "number" },
        "scaleX": { "type": "number" },
        "scaleY": { "type": "number" },
        "zIndex": { "type": "number" },
        "members": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pageId", "type", "x", "y", "members"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile documents."
        }
      },
      {
        "path": "/scrapbooks/{scrapbookId}",
        "definition": {
          "entityName": "Scrapbook",
          "schema": { "$ref": "#/backend/entities/Scrapbook" },
          "description": "Collaborative scrapbooks."
        }
      },
      {
        "path": "/scrapbooks/{scrapbookId}/pages/{pageId}",
        "definition": {
          "entityName": "Page",
          "schema": { "$ref": "#/backend/entities/Page" },
          "description": "Pages in a scrapbook."
        }
      },
      {
        "path": "/scrapbooks/{scrapbookId}/pages/{pageId}/canvasObjects/{canvasObjectId}",
        "definition": {
          "entityName": "CanvasObject",
          "schema": { "$ref": "#/backend/entities/CanvasObject" },
          "description": "Objects on a page canvas."
        }
      }
    ]
  }
}
