
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * RECURSIVE STORAGE RULES
     * Allows authenticated users to read and write to any path under /scrapbooks.
     * This recursive wildcard {allPaths=**} is critical for deep folder structures.
     */
    match /scrapbooks/{allPaths=**} {
       // Permissive rule for authenticated users to bypass "Unauthorized" errors during dev.
       allow read, write: if request.auth != null;
    }

    // Specific ownership logic (for future production hardening)
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
