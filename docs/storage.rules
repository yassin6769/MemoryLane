rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * PERMISSIVE ACCESS FOR SCRAPBOOKS
     * Allows any authenticated user to read and write to the /scrapbooks path.
     * The recursive wildcard {allPaths=**} ensures that deep paths like 
     * /scrapbooks/{scrapbookId}/{userId}/{fileName} are covered.
     */
    match /scrapbooks/{allPaths=**} {
       allow read, write: if request.auth != null;
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}