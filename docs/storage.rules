
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * SCRAPBOOK STORAGE RULES
     * Path: /scrapbooks/{scrapbookId}/{userId}/{fileName}
     */
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      // Allow any authenticated user to read (for collaboration/viewing)
      allow read: if request.auth != null;
      
      // STRICT WRITE: Only the user matching the folder name can upload/delete
      // Also enforces a 5MB limit and image/video/audio content types
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024
                  && (
                    request.resource.contentType.matches('image/.*') ||
                    request.resource.contentType.matches('video/.*') ||
                    request.resource.contentType.matches('audio/.*')
                  );
    }

    /**
     * RECURSIVE CATCH-ALL (For troubleshooting)
     * If the specific path above fails, this recursive wildcard ensures 
     * that permissions are evaluated for any depth.
     */
    match /scrapbooks/{allPaths=**} {
       // TEMPORARY: Uncomment the line below to test if rules are the root cause
       // allow read, write: if request.auth != null;
       allow read: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
