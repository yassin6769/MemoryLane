
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * NUCLEAR TEST RULE (Temporary for debugging)
     * allows read and write access to all files in the 'scrapbooks' path.
     * WARNING: Revert this to specific path-based rules once the connection is verified.
     */
    match /scrapbooks/{allPaths=**} {
      allow read, write: if true;
    }

    /**
     * Standard Hierarchical Security Model (Reference)
     * Path: /scrapbooks/{scrapbookId}/{userId}/{fileName}
     */
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      // Allow viewing by any authenticated user for collaboration
      allow read: if request.auth != null;
      
      // Strict write access control: Only the owner of the folder can write
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && (
                    request.resource.contentType.matches('image/.*') ||
                    request.resource.contentType.matches('video/.*') ||
                    request.resource.contentType.matches('audio/.*')
                  )
                  && request.resource.size < 5 * 1024 * 1024; // 5MB limit
      
      // Allow delete only by owner
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
