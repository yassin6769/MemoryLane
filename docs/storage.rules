
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * SCRAPBOOK STORAGE RULES
     * Recursive access for authenticated users to bypass folder-level blocks during dev.
     */
    match /scrapbooks/{allPaths=**} {
       // Permissive rule for authenticated users to resolve "Unauthorized" errors
       allow read, write: if request.auth != null;
    }

    // Specific path logic for future tightening
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
