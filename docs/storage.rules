
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * MemoryLane Storage Rules
     * 
     * Path: /scrapbooks/{scrapbookId}/{userId}/{fileName}
     * 1. Users must be authenticated.
     * 2. Users can only write to paths containing their own UID.
     * 3. Max file size: 5MB.
     */
    
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      // Allow read if authenticated (membership check is handled by the UI/Firestore)
      allow read: if request.auth != null;
      
      // Allow write if the user matches the path UID and file is < 5MB
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
