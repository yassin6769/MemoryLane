rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * NUCLEAR PERMISSION FIX
     * Allows all users (even unauthenticated ones for this test) to read and write to the /scrapbooks path.
     * Use this to determine if the issue is rule-based or configuration-based.
     * Path structure: /scrapbooks/{scrapbookId}/{userId}/{fileName}
     */
    match /scrapbooks/{allPaths=**} {
       allow read, write: if true;
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}