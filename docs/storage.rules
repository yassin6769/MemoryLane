
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /**
     * MemoryLane Storage Rules
     * 
     * TEMPORARY DEBUG RULE: Allow all authenticated uploads to isolate CORS/Initialization issues.
     * This rule should be narrowed after verifying that uploads work.
     */
    
    match /{allPaths=**} {
      // Allow read/write if authenticated
      allow read, write: if request.auth != null;
    }

    // Original structure kept for reference when reverting to strict rules
    /*
    match /scrapbooks/{scrapbookId}/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024;
    }
    */
  }
}
