
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the bucket for read and write access for all users.
     * DEPLOYMENT TRIGGER: 2025-05-26T02:15:00Z (NETWORK_RECOVERY)
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
