rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the bucket for read and write access for all users.
     * DEPLOYMENT TRIGGER: 2024-05-20T12:00:00Z (Forces re-sync with Firebase)
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}