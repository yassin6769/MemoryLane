
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the bucket for read and write access for all users.
     * DEPLOYMENT TRIGGER: 2025-05-25T23:00:00Z (EDITABLE_TEXT)
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
