
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MemoryLane Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust, collaborative security model designed for rapid prototyping.
     * It prioritizes "Authorization Independence" by relying on denormalized membership data 
     * within documents to avoid costly cross-document lookups (get() calls).
     * 
     * Updates: 
     * - Added support for 'isPublic' visibility on scrapbooks.
     * - Improved 'get' rules to handle non-existent documents gracefully.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the current user is a member of the document (owner, editor, or viewer)
    function isMember(data) {
      return isSignedIn() && 
             data != null && 
             "members" in data && 
             data.members[request.auth.uid] != null;
    }

    // Checks if the current user has write/edit permissions
    function canEdit(data) {
      return isSignedIn() && (
        data.members[request.auth.uid] == 'owner' || 
        data.members[request.auth.uid] == 'editor' ||
        data.ownerId == request.auth.uid
      );
    }

    // Checks if the current user is the primary owner
    function isDocOwner(data) {
      return isSignedIn() && (
        data.members[request.auth.uid] == 'owner' ||
        data.ownerId == request.auth.uid
      );
    }

    // Checks if a scrapbook or its parent is public
    function isPublic(data) {
      return data != null && data.isPublic == true;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if false;
    }

    match /scrapbooks/{scrapbookId} {
      allow list: if isSignedIn();
      // Allow get if the document doesn't exist (returns null), if it's public, or if the user is a member/owner
      allow get: if isSignedIn() && (resource == null || isPublic(resource.data) || isMember(resource.data) || isDocOwner(resource.data));
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if canEdit(resource.data);
      allow delete: if isDocOwner(resource.data);

      match /pages/{pageId} {
        allow list: if isSignedIn();
        // Pages inherit visibility from their parent scrapbook via the 'get' helper or denormalized members
        allow get: if isSignedIn() && (resource == null || isMember(resource.data) || isDocOwner(resource.data) || get(/databases/$(database)/documents/scrapbooks/$(scrapbookId)).data.isPublic == true);
        allow create: if isSignedIn() && isMember(request.resource.data);
        allow update: if canEdit(resource.data);
        allow delete: if isDocOwner(resource.data);

        match /canvasObjects/{canvasObjectId} {
          allow list: if isSignedIn();
          allow get: if isSignedIn() && (resource == null || isMember(resource.data) || isDocOwner(resource.data) || get(/databases/$(database)/documents/scrapbooks/$(scrapbookId)).data.isPublic == true);
          allow create: if isSignedIn() && isMember(request.resource.data);
          allow update: if canEdit(resource.data);
          allow delete: if isDocOwner(resource.data);
        }
      }
    }

    match /users/{userId}/scrapbookInvitations/{invitationId} {
      allow get, list: if isOwner(userId);
      allow create: if isSignedIn() && request.resource.data.userId == userId;
      allow update, delete: if isOwner(userId);
    }
  }
}
