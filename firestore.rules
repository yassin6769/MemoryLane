rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the database for read and write access.
     * Ensures that text objects and media metadata are always saved.
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}