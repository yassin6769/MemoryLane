rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the database for read and write access for all users.
     * DEPLOYMENT TRIGGER: 2024-05-20T12:00:00Z (Forces re-sync with Firebase)
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}