rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * NUCLEAR PERMISSION FIX
     * Completely opens the database for read and write access for all users.
     * DEPLOYMENT TRIGGER: 2025-05-25T16:15:00Z (FORCED RE-SYNC)
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}